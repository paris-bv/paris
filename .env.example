# ─── SMTP-instellingen voor het contactformulier ───────────────────────
# Zet deze waarden in Vercel: Project → Settings → Environment Variables
# (en lokaal in een bestand .env.local — die staat in .gitignore)

# SMTP-server van je e-mail-/hostingprovider
SMTP_HOST=smtp.jouwprovider.nl

# Poort: 587 (STARTTLS, gebruikelijk) of 465 (SSL)
SMTP_PORT=587

# Laat leeg voor automatisch (true bij poort 465, anders false).
# Zet expliciet op "true" of "false" als je provider iets anders vraagt.
SMTP_SECURE=

# Inloggegevens van het mailaccount waarmee verzonden wordt
SMTP_USER=info@paris-bv.nl
SMTP_PASS=jouw-wachtwoord-of-app-wachtwoord

# Afzender (optioneel). Bij de meeste providers moet dit hetzelfde
# domein/adres zijn als SMTP_USER, anders wordt de mail geweigerd.
SMTP_FROM="Paris BV website <info@paris-bv.nl>"

# Naar welk adres de aanvragen gestuurd worden (optioneel).
CONTACT_TO=info@paris-bv.nl
